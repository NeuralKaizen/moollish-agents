OPENROUTER_API_KEY=sk-or-...
# Slug OpenRouter. Default liviano para MVP económico; debe soportar structured output.
# Verificar el más nuevo en https://openrouter.ai/api/v1/models
AGENT_MODEL=google/gemini-2.5-flash
# UI: poné 1 para usar el fixture local sin pegarle al LLM (desarrollo de UI)
NEXT_PUBLIC_USE_FIXTURE=0
# Firecrawl: lectura web con render JS + parseo de PDFs remotos (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-...
# Caps de ingestión (opcionales, ver lib/ingest/config.ts)
INGEST_MAX_DOCS=5
INGEST_MAX_CHARS_PER_DOC=40000
INGEST_TOTAL_BUDGET=120000
FIRECRAWL_TIMEOUT_MS=30000
# Postgres de Supabase (connection string pooled, puerto 6543). Solo en .env.local, nunca commitear el valor real.
DATABASE_URL=
